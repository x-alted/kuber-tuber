[Unit]
Description=LoRa Bridge to Kubernetes
After=network.target k3s.service
Wants=k3s.service

[Service]
User=pi
WorkingDirectory=/home/pi/kuber-tuber/LoRa/gateway
ExecStart=/home/pi/kuber-tuber/LoRa/venv/bin/python /home/pi/kuber-tuber/LoRa/gateway/LoRa-Bridge.py
Restart=always
RestartSec=10
Environment=KUBECONFIG=/etc/rancher/k3s/k3s.yaml

[Install]
WantedBy=multi-user.target
